#include "winver.h"

// note that the icon used by the Explorer (i.e. the programs icon) is the
// first icon in the executable and the icons are sorted both by their order
// and alphabetically (!), so put this icon first and give it a name
// starting with "a"
aaaaaaaa ICON "ripe.ico"

// this icon is used with wxFrame::SetIcon()
CeresFileVerification ICON "ripe.ico"

// set this to 1 if you don't want to use manifest resource (manifest resource
// is needed to enable visual styles on Windows XP - see docs/msw/winxp.txt
// for more information)
#define wxUSE_NO_MANIFEST 0

// this is not always needed but doesn't hurt (except making the executable
// very slightly larger): this file contains the standard icons, cursors, ...
#include "wx/msw/wx.rc"

//IDI_ICON1               ICON    DISCARDABLE     "Icons/ripe.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @daily_checker_VERSION_MAJOR@,@daily_checker_VERSION_MINOR@,@daily_checker_VERSION_PATCH@,@daily_checker_VERSION_TWEAK@
 PRODUCTVERSION @daily_checker_VERSION_MAJOR@,@daily_checker_VERSION_MINOR@,@daily_checker_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x00040004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "000004b0"
        BEGIN
            VALUE "CompanyName", "University of Illinois at Urbana-Champaign"
            VALUE "FileDescription", "Ceres Daily Checker Software"
            VALUE "FileVersion", "@daily_checker_VERSION_MAJOR@.@daily_checker_VERSION_MINOR@.@daily_checker_VERSION_PATCH@.@daily_checker_VERSION_TWEAK@\0"
            VALUE "LegalCopyright", "Copyright (C) 2022..2026 UIUC"
            VALUE "InternalName", "CeresDailyChecker"
            VALUE "OriginalFilename", "CeresDailyChecker.exe"
            VALUE "ProductName", "CeresDailyChecker"
            VALUE "ProductVersion", "@daily_checker_VERSION_MAJOR@.@daily_checker_VERSION_MINOR@.@daily_checker_VERSION_PATCH@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0, 1200
    END
END
