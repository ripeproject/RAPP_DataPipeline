
#include "version.hpp"

std::string getVersionString()
{
	return "@daily_checker_VERSION@";
}

unsigned int getMajorVersion()
{
	return @daily_checker_VERSION_MAJOR@ +0;
}

unsigned int getMinorVersion()
{
	return @daily_checker_VERSION_MINOR@ +0;
}

unsigned int getPatchVersion()
{
	return @daily_checker_VERSION_PATCH@ +0;
}

unsigned int getTweakVersion()
{
	return @daily_checker_VERSION_TWEAK@ +0;
}
